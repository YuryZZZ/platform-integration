# ─────────────────────────────────────────────────────────────
# NEXUS / PORTAL PROJECT — Environment Variables
# Copy this to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────
# CORE APPLICATION
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SERVER_URL=http://localhost:3001
PAYLOAD_SECRET=minimum-32-character-secret-here
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3001

# ─────────────────────────────────────────────────────────────
# DATABASE — PostgreSQL (Control Plane only)
# ─────────────────────────────────────────────────────────────
# Local dev / Cloud SQL Auth Proxy:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nexus_ai

# Google Cloud SQL (Cloud Run / GKE — uses Unix socket):
# CLOUD_SQL_CONNECTION_NAME=project:region:instance
# DATABASE_NAME=nexus_ai
# DATABASE_USER=postgres
# DATABASE_PASSWORD=your-password
# Or use IAM auth (no password needed):
# CLOUD_SQL_IAM_USER=service-account@project.iam.gserviceaccount.com

# ─────────────────────────────────────────────────────────────
# AI MODELS (any combination — the gateway auto-detects)
# ─────────────────────────────────────────────────────────────
# Google Gemini (AI Studio — preferred)
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-key

# GLM / Z.AI
GLM_API_KEY=your-glm-api-key
GLM_BASE_URL=https://open.bigmodel.ai/api/paas/v4

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-key

# Moonshot / Kimi
MOONSHOT_API_KEY=your-moonshot-key

# Vertex AI (uses GCloud service account auth)
VERTEX_PROJECT=your-gcp-project

# Custom OpenAI-compatible endpoint (any provider)
# CUSTOM_LLM_BASE_URL=https://your-endpoint.com/v1
# CUSTOM_LLM_API_KEY=your-key

# Default model (auto-detected if not set)
# DEFAULT_MODEL=gemini-2.0-flash

# ─────────────────────────────────────────────────────────────
# GITHUB INTEGRATION
# ─────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY=LS0tLS1CRUdJTi...
GITHUB_APP_INSTALLATION_ID=12345678
GITHUB_WEBHOOK_SECRET=your-hmac-secret
GITHUB_DEFAULT_ORG=your-org-name

# ─────────────────────────────────────────────────────────────
# GOOGLE CLOUD SERVICES (full toolset)
# ─────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# On Cloud Run/GKE these are auto-provided via metadata server

# ─────────────────────────────────────────────────────────────
# STITCH + ANTIGRAVITY INTEGRATION
# ─────────────────────────────────────────────────────────────
STITCH_API_KEY=your-stitch-api-key
STITCH_MCP_SERVER_PATH=
ANTIGRAVITY_API_KEY=your-antigravity-key
ANTIGRAVITY_WORKSPACE_PATH=/tmp/nexus-ag-workspace
GOOGLE_AI_STUDIO_API_KEY=your-ai-studio-key

# ─────────────────────────────────────────────────────────────
# FIREBASE INTEGRATION (Generated Site Runtime — Layer 2)
# ─────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_KEY=eyJxxxxxxxxxx
FIREBASE_PROJECT_ID=your-firebase-project
GOOGLE_CLOUD_PROJECT=your-firebase-project
FIREBASE_APP_HOSTING_REGION=us-central1

# ─────────────────────────────────────────────────────────────
# LOVABLE INTEGRATION
# ─────────────────────────────────────────────────────────────
LOVABLE_API_KEY=your-lovable-key
LOVABLE_ORG_ID=your-org-id
LOVABLE_DEFAULT_STACK=react-supabase
LOVABLE_WEBHOOK_SECRET=your-lovable-webhook-secret

# ─────────────────────────────────────────────────────────────
# JULES INTEGRATION
# ─────────────────────────────────────────────────────────────
JULES_API_KEY=your-jules-api-key

# ─────────────────────────────────────────────────────────────
# FEATURE FLAGS
# ─────────────────────────────────────────────────────────────
FEATURE_FLUID_MOTION=true
FEATURE_SONIC=false
AI_FEATURE_ENABLED=true

# ─────────────────────────────────────────────────────────────
# OBSERVABILITY (Optional)
# ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=nexus-ai
SENTRY_DSN=
