rules_version = '2';

// ─────────────────────────────────────────────────────────────
// FIRESTORE SECURITY RULES — Generated Site Runtime (Layer 2)
// ─────────────────────────────────────────────────────────────
// These rules govern the Firebase Firestore database for
// generated client portals. They do NOT apply to the Nexus
// control plane (PostgreSQL Layer 1).
//
// See: docs/PROJECT_SPEC.md — Data Layer Map
// See: docs/FIREBASE_PROMPT_GUIDE.md — Security Rules Generation
// ─────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── User Profiles ──────────────────────────────────────
    // Users can read/write their own profile. Admins can read all.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    // ─── Projects Collection ────────────────────────────────
    // Authenticated users can read projects they belong to.
    // Only project owners or admins can write.
    match /projects/{projectId} {
      allow read: if isAuthenticated() &&
        (request.auth.uid in resource.data.memberIds || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        (request.auth.uid == resource.data.ownerId || isAdmin());
      allow delete: if isAdmin();

      // ─── Project Subcollections ───────────────────────────
      match /documents/{docId} {
        allow read: if isAuthenticated() &&
          (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.memberIds);
        allow write: if isAuthenticated() &&
          (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.memberIds);
      }
    }

    // ─── Admin Logs (Read-only for admins) ──────────────────
    // No client-side writes. Logs are written by Cloud Functions only.
    match /admin_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ─── Public Content (Read-only) ─────────────────────────
    match /public/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Default Deny ───────────────────────────────────────
    // Everything not explicitly matched above is denied.
  }
}
